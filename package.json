{
  "name": "youtube-downloader",
  "version": "0.2.1",
  "description": "Servidor REST para descargar videos/audio de YouTube",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "cli": "node download.js",
    "build": "npx pkg@5.8.1 index.js --output youtube-downloader.exe --targets node18-win-x64",
    "cp-yd": "copy youtube-downloader.exe homecontrol\\build\\windows\\x64\\runner\\Release\\youtube-downloader.exe",
    "cp-yt": "copy yt-dlp.exe homecontrol\\build\\windows\\x64\\runner\\Release\\yt-dlp.exe",
    "cp-ff": "copy ffmpeg.exe homecontrol\\build\\windows\\x64\\runner\\Release\\ffmpeg.exe",
    "cp": "npm run cp-yd && npm run cp-yt && npm run cp-ff",
    "bf": "npm run build && npm run cp"

  },
  "pkg": {
    "assets": [
      "yt-dlp.exe",
      "ffmpeg.exe"
    ],
    "scripts": [
      "logger.js"
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^2.1.1"
  }
}
