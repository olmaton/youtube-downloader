{
  "name": "youtube-downloader",
  "version": "2.0.0",
  "description": "Servidor REST para descargar videos/audio de YouTube",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "cli": "node download.js",
    "build": "npx pkg@5.8.1 index.js --output youtube-downloader.exe --targets node18-win-x64"
  },
  "pkg": {
    "assets": [
      "yt-dlp.exe",
      "ffmpeg.exe"
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^2.1.1"
  }
}
